{
  "version": 1,
  "name": "Order Samurai Root Hygiene Policy",
  "directories": {
    "live": [
      "execution",
      "agentica_core",
      "scouts",
      "api",
      "dashboard-ui",
      "backlog",
      "reports"
    ],
    "support": [
      "bin",
      "config",
      "docs",
      "platform_surfaces",
      "prompts",
      "schema",
      "soji",
      "go-to-market",
      "Research",
      "tests"
    ],
    "state": [
      ".claude",
      ".mex",
      ".impeccable",
      ".pytest_cache",
      ".ruff_cache",
      ".tmp",
      "artifacts",
      "state",
      "test_env",
      "Order Samurai",
      "__pycache__"
    ],
    "metadata": [
      ".git"
    ],
    "archive": [
      "archive",
      "playground",
      "scratch"
    ],
    "dependency": [
      "node_modules"
    ]
  },
  "files": {
    "metadata": [
      ".gitignore",
      "AGENTS.md",
      "README.md",
      "LICENSE",
      "CHANGELOG.md",
      "CODE_OF_CONDUCT.md",
      "CONTRIBUTING.md",
      "EULA.md",
      "PRIVACY.md",
      "SECURITY.md",
      "TERMS.md",
      "HANDOFF.md",
      "CLAUDE.md",
      "PROJECT.md",
      "RONIN_SPEC.md",
      ".quality_register.md"
    ],
    "support": [
      "pyproject.toml",
      "package.json",
      "package-lock.json",
      "install.sh",
      "verify.sh",
      "refresh_dashboard.py",
      "governance_review.py",
      "build_perfect_pillars_gifs.py",
      "compile_dashboard_simulation_gif.py",
      "convert_pngs_to_gifs.py",
      "generate_perfect_gifs.js",
      "record_dashboard_walkthrough.js"
    ]
  },
  "requiredDirectories": [
    "config",
    "execution",
    "tests"
  ],
  "requiredFiles": [
    "AGENTS.md",
    "README.md"
  ],
  "boundaryRules": [
    {
      "name": "archive-isolation",
      "scanPaths": [
        "execution"
      ],
      "forbiddenRoots": [
        "archive",
        "playground",
        "scratch"
      ],
      "description": "Live runtime code must not depend on archive or exploratory roots."
    }
  ]
}
