#!/usr/bin/env bash
# ronin — arm/disarm/status/propose/promote CLI for the Order Samurai daemon lifecycle.
set -euo pipefail

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

STATE_DIR="$REPO_DIR/state"
ARTIFACTS_DIR="$REPO_DIR/artifacts"
BIN_DIR="$REPO_DIR/bin"

DAEMON_SCRIPT="$BIN_DIR/ronin-daemon.sh"
PID_FILE="$STATE_DIR/daemon.pid"
STOP_FILE="$REPO_DIR/DOJO_STOP"
LEDGER_FILE="$STATE_DIR/budget_ledger.json"
PROPOSED_FILE="$STATE_DIR/PROPOSED_BACKLOG.json"
STATE_FILE="$STATE_DIR/DOJO_STATE.json"
LOG_FILE="$ARTIFACTS_DIR/ronin_logs.md"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
_err()  { echo "ronin: ERROR: $*" >&2; exit 1; }
_info() { echo "ronin: $*"; }

_pid_running() {
  local pid="${1:-}"
  [[ -z "$pid" ]] && return 1
  kill -0 "$pid" 2>/dev/null
}

_read_pid() {
  [[ -f "$PID_FILE" ]] || { echo ""; return; }
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || echo "")"
  echo "$pid"
}

_require_jq() {
  command -v jq >/dev/null 2>&1 || _err "jq is required but not found in PATH"
}

_require_python() {
  command -v python >/dev/null 2>&1 \
    || command -v python3 >/dev/null 2>&1 \
    || _err "python/python3 is required but not found in PATH"
}

_python() {
  if command -v python3 >/dev/null 2>&1; then python3 "$@"; else python "$@"; fi
}

# ---------------------------------------------------------------------------
# arm
# ---------------------------------------------------------------------------
cmd_arm() {
  _require_jq

  # 1. Check clean git tree
  if git -C "$REPO_DIR" rev-parse --git-dir >/dev/null 2>&1; then
    local dirty
    dirty="$(git -C "$REPO_DIR" status --porcelain 2>/dev/null || true)"
    if [[ -n "$dirty" ]]; then
      echo "ronin: WARNING: working tree is not clean:"
      echo "$dirty"
      echo "ronin: Continuing arm with dirty tree (not blocking)."
    else
      _info "Working tree is clean."
    fi
  else
    _info "Not a git repo — skipping tree check."
  fi

  # 2. Remove DOJO_STOP if present
  if [[ -f "$STOP_FILE" ]]; then
    rm -f "$STOP_FILE"
    _info "Removed DOJO_STOP."
  fi

  # 3. Check if daemon already running
  local existing_pid
  existing_pid="$(_read_pid)"
  if [[ -n "$existing_pid" ]] && _pid_running "$existing_pid"; then
    _info "Daemon already running (PID $existing_pid). Nothing to do."
    return 0
  fi

  # 4. Require daemon script
  [[ -f "$DAEMON_SCRIPT" ]] || _err "Daemon script not found: $DAEMON_SCRIPT"
  [[ -x "$DAEMON_SCRIPT" ]] || chmod +x "$DAEMON_SCRIPT"

  # 5. Launch with nohup, redirect output to log
  mkdir -p "$ARTIFACTS_DIR"
  local nohup_log="$ARTIFACTS_DIR/ronin_daemon_nohup.log"
  nohup "$DAEMON_SCRIPT" >> "$nohup_log" 2>&1 &
  local new_pid=$!

  # 6. Save PID
  mkdir -p "$STATE_DIR"
  echo "$new_pid" > "$PID_FILE"

  _info "Daemon started (PID $new_pid)."
  _info "Log: $nohup_log"
  _info "PID file: $PID_FILE"
  _info "Status: ARMED"
}

# ---------------------------------------------------------------------------
# disarm
# ---------------------------------------------------------------------------
cmd_disarm() {
  # 1. Create DOJO_STOP
  touch "$STOP_FILE"
  _info "DOJO_STOP created — daemon will halt at next cycle check."

  # 2. SIGTERM the daemon if running
  local pid
  pid="$(_read_pid)"
  if [[ -n "$pid" ]] && _pid_running "$pid"; then
    kill -TERM "$pid" 2>/dev/null && _info "Sent SIGTERM to PID $pid." \
      || _info "SIGTERM failed for PID $pid (may have already exited)."
  else
    _info "No running daemon found (PID file: ${pid:-none})."
  fi

  # 3. Print final log path
  _info "Final log: $LOG_FILE"
}

# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------
cmd_status() {
  _require_jq

  echo "=== Ronin Status ==="

  # Running / stopped
  local pid
  pid="$(_read_pid)"
  if [[ -n "$pid" ]] && _pid_running "$pid"; then
    echo "Daemon  : RUNNING (PID $pid)"
  else
    echo "Daemon  : STOPPED${pid:+ (last PID $pid)}"
  fi

  # DOJO_STOP
  if [[ -f "$STOP_FILE" ]]; then
    echo "Stop    : DOJO_STOP present"
  else
    echo "Stop    : no DOJO_STOP"
  fi

  # Daily spend from budget_ledger.json
  if [[ -f "$LEDGER_FILE" ]]; then
    local spent date daily_limit
    spent="$(jq -r '.spent_usd // "n/a"' "$LEDGER_FILE")"
    date="$(jq -r '.date // "n/a"' "$LEDGER_FILE")"
    daily_limit="$(jq -r '.daily_limit_usd // "n/a"' "$LEDGER_FILE")"
    cycles_today="$(jq -r '.cycles_today // "n/a"' "$LEDGER_FILE")"
    echo "Spend   : \$${spent} / \$${daily_limit} (date: ${date})"
    echo "Cycles  : ${cycles_today} today"
  else
    echo "Spend   : budget_ledger.json not found"
  fi

  # Cycle count from DOJO_STATE.json
  if [[ -f "$STATE_FILE" ]]; then
    local cycle
    cycle="$(jq -r '.cycle // "n/a"' "$STATE_FILE")"
    echo "Cycle   : ${cycle} (lifetime)"
  fi

  # Last log line
  if [[ -f "$LOG_FILE" ]]; then
    local last_line
    last_line="$(grep -v '^[[:space:]]*$' "$LOG_FILE" 2>/dev/null | tail -n 1 || echo "(empty)")"
    echo "Last log: ${last_line}"
  else
    echo "Last log: $LOG_FILE not found"
  fi

  # Proposed backlog count
  if [[ -f "$PROPOSED_FILE" ]]; then
    local proposed_count
    proposed_count="$(jq '.items | length' "$PROPOSED_FILE" 2>/dev/null || echo "0")"
    local approved_count
    approved_count="$(jq '[.items[] | select(.approved == true)] | length' "$PROPOSED_FILE" 2>/dev/null || echo "0")"
    echo "Proposed: ${proposed_count} items (${approved_count} approved)"
  else
    echo "Proposed: PROPOSED_BACKLOG.json not found"
  fi
}

# ---------------------------------------------------------------------------
# propose
# ---------------------------------------------------------------------------
cmd_propose() {
  _require_python
  [[ -f "$PROPOSED_FILE" ]] || _err "PROPOSED_BACKLOG.json not found: $PROPOSED_FILE"
  _python -m json.tool "$PROPOSED_FILE"
}

# ---------------------------------------------------------------------------
# promote
# ---------------------------------------------------------------------------
cmd_promote() {
  _require_jq
  _require_python

  [[ -f "$PROPOSED_FILE" ]] || _err "PROPOSED_BACKLOG.json not found: $PROPOSED_FILE"
  [[ -f "$STATE_FILE" ]]    || _err "DOJO_STATE.json not found: $STATE_FILE"

  # Read approved items
  local approved_json
  approved_json="$(jq '[.items[] | select(.approved == true)]' "$PROPOSED_FILE")"
  local count
  count="$(echo "$approved_json" | jq 'length')"

  if [[ "$count" -eq 0 ]]; then
    _info "No approved items to promote."
    return 0
  fi

  # Strip the approved/proposed-only fields before merging into backlog (keep id, pillar, kind, title, value, effort, status etc.)
  # We keep all fields — the backlog array in DOJO_STATE.json carries the same schema.

  # 1. Append approved items to DOJO_STATE.json backlog array
  local updated_state
  updated_state="$(jq --argjson new_items "$approved_json" \
    '.backlog = ((.backlog // []) + $new_items)' "$STATE_FILE")"
  echo "$updated_state" > "$STATE_FILE"

  # 2. Remove promoted items from PROPOSED_BACKLOG.json (keep items where approved != true)
  local updated_proposed
  updated_proposed="$(jq '.items = [.items[] | select(.approved != true)]' "$PROPOSED_FILE")"
  echo "$updated_proposed" > "$PROPOSED_FILE"

  _info "Promoted $count item(s) to DOJO_STATE.json backlog."
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
Usage: ronin <command>

Commands:
  arm       Check clean tree, remove DOJO_STOP, start ronin-daemon.sh in background
  disarm    Create DOJO_STOP, SIGTERM daemon, print final log path
  status    Show running/stopped, daily spend, cycle count, last log line, proposed count
  propose   Pretty-print state/PROPOSED_BACKLOG.json
  promote   Move approved==true items from PROPOSED_BACKLOG.json into DOJO_STATE.json backlog
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
CMD="${1:-}"
case "$CMD" in
  arm)     cmd_arm     ;;
  disarm)  cmd_disarm  ;;
  status)  cmd_status  ;;
  propose) cmd_propose ;;
  promote) cmd_promote ;;
  ""|--help|-h) usage; exit 0 ;;
  *) echo "ronin: unknown command: $CMD" >&2; usage; exit 1 ;;
esac
